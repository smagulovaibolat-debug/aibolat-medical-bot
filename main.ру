import os
import telebot
import google.generativeai as genai

# Настройка API
TELEGRAM_TOKEN = os.environ.get('TELEGRAM_TOKEN')
GEMINI_KEY = os.environ.get('GEMINI_KEY')
VIDEO_NOTE_ID = os.environ.get('VIDEO_NOTE_ID') # Видеоның ID-і

genai.configure(api_key=GEMINI_KEY)
model = genai.GenerativeModel('gemini-1.5-flash')
bot = telebot.TeleBot(TELEGRAM_TOKEN)

SYSTEM_PROMPT = """Сен — хирург-онкологиялық орталық директорының орынбасары Айболат Смагуловтың цифрлық көмекшісісің. 
Тілің: Қазақ тілі. Сөйлеу мәнерің: Эмпатиялық, қолдау көрсететін, кәсіби. 
Әр жауапты жылы сөзбен бастап, пациентті тыныштандыр. Содан кейін қажетті анализдерді ұсын. 
Міндетті түрде: 'Бұл ақпарат тек танысу үшін, нақты диагнозды дәрігер қояды' деп ескерт."""

@bot.message_handler(commands=['start'])
def send_welcome(message):
    bot.reply_to(message, "Сәлеметсіз бе! Мен доктор Айболаттың көмекшісімін. Сізді не мазалайды?")

@bot.message_handler(func=lambda message: True)
def handle_message(message):
    # Gemini-ден жауап алу
    chat = model.start_chat(history=[])
    response = chat.send_message(f"{SYSTEM_PROMPT}\n\nПациент сұрағы: {message.text}")
    
    # Видео-кружочек жіберу (егер ID болса)
    if VIDEO_NOTE_ID:
        bot.send_video_note(message.chat.id, VIDEO_NOTE_ID)
    
    # Текст жауабын жіберу
    bot.send_message(message.chat.id, response.text)

bot.infinity_polling()
